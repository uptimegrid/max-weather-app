// Build pipeline for max-weather-app.
//
// Responsibility: build the container image from this repository and push it to
// Amazon ECR with an immutable tag. Deployment/promotion is handled separately
// by the max-weather-platform deploy pipeline, which consumes this image tag.
//
// Agent requirements (self-hosted): docker, aws CLI v2.
// The agent's IAM role/credentials need ECR push permission.

pipeline {
  agent any

  // The controller is private (no inbound internet), so GitHub webhooks cannot
  // reach it. Poll GitHub every ~2 min (outbound via NAT) and build on a new
  // commit, mirroring the infra pipeline's trigger.
  triggers {
    pollSCM('H/2 * * * *')
  }

  environment {
    AWS_REGION = 'ap-southeast-1'
    // <account-id>.dkr.ecr.<region>.amazonaws.com (Terraform output: repository_url without the repo name)
    ECR_REGISTRY = '638599595074.dkr.ecr.ap-southeast-1.amazonaws.com'
    // ECR repository name (Terraform output: repository_url's last path segment).
    ECR_REPO     = 'mw-prd-apse1-ecr-01'
    IMAGE_TAG    = "${env.GIT_COMMIT?.take(12) ?: env.BUILD_NUMBER}"
  }

  stages {
    stage('Login To ECR') {
      steps {
        sh '''
          aws ecr get-login-password --region "$AWS_REGION" \
            | docker login --username AWS --password-stdin "$ECR_REGISTRY"
        '''
      }
    }

    stage('Build And Push') {
      steps {
        sh '''
          docker build -t "$ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG" .
          docker push "$ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG"
          echo "Pushed $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG"
        '''
      }
    }
  }

  post {
    success {
      echo "Image tag to deploy: ${IMAGE_TAG}"
    }
  }
}
